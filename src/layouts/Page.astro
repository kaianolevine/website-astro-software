---
import Base from "./Base.astro";

const { title, subtitle } = Astro.props as {
  title: string;
  subtitle?: string;
};
---

<Base title={title} description={subtitle ?? title}>
  <section class="space-y-5">
    <header>
      <h1 class="font-display text-3xl tracking-tight sm:text-4xl">
        {title}
      </h1>
      {subtitle ? (
        <p class="mt-2 text-sm text-slate-400">{subtitle}</p>
      ) : null}
    </header>
    <div class="pt-2">
      <slot />
    </div>
  </section>
</Base>

