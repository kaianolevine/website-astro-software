---
import Page from "../../layouts/Page.astro";
import SetsList from "../../components/SetsList.astro";

const maxYear = 2026;
const minYear = 2016;
const years = Array.from({ length: maxYear - minYear + 1 }, (_, i) => maxYear - i);
// Keep subtitle deterministic: the browser fetches live set history data.
const subtitle = `438 sets · ${minYear}–${maxYear}`;
---

<Page title="Set History" subtitle={subtitle}>
  <SetsList years={years} initialYear={maxYear} />
</Page>

