---
export type ProjectCardProps = {
  title: string;
  description: string;
  status: string;
  link?: string;
};

const { title, description, status, link } = Astro.props as ProjectCardProps;
---

<article
  class="group rounded-2xl border border-white/10 bg-white/[0.02] p-6 shadow-soft transition-colors hover:border-white/20"
>
  <header class="flex items-start justify-between gap-4">
    <div>
      <h2 class="font-display text-xl tracking-tight">{title}</h2>
      <p class="mt-2 text-sm leading-relaxed text-slate-300">{description}</p>
    </div>
    <div class="shrink-0 rounded-full border border-white/10 bg-black/20 px-3 py-1">
      <span class="font-mono text-xs text-accent">{status}</span>
    </div>
  </header>

  {link ? (
    <a
      href={link}
      target="_blank"
      rel="noreferrer"
      class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-slate-200 transition-colors hover:text-accent"
    >
      <span>GitHub</span>
      <span aria-hidden="true" class="font-mono">
        ↗
      </span>
    </a>
  ) : null}
</article>

